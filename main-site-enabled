server {
       server_name langnostic.inaimathi.ca langnostic.inaimathi.com blog.inaimathi.com blog.inaimathi.ca inaimathi.ca inaimathi.com www.inaimathi.ca www.inaimathi.com 138.197.135.113;

       rewrite .*/favicon.ico /static/img/favicon.ico last;

        location /static/ {
           alias /home/inaimathi/langnostic/resources/public/;
           expires 30d;
        }

        location / {
                proxy_pass http://localhost:4444;
                proxy_redirect off;
                proxy_set_header Host $host;
                proxy_set_header X-Real-IP $remote_addr;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                client_max_body_size 10m;
                client_body_buffer_size 128k;
                proxy_connect_timeout 90;
                proxy_send_timeout 90;
                proxy_read_timeout 90;
                proxy_buffer_size 4k;
                proxy_buffers 4 32k;
                proxy_busy_buffers_size 64k;
                proxy_temp_file_write_size 64k;
        }
}
